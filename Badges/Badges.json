  "filters": [
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-r",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-remux.png",
      "isEnabled": true,
      "name": "Remux",
      "pattern": "(?i)\\bremux\\b",
      "tagColor": "#1A1A1A",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-b",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-bluray.png",
      "isEnabled": true,
      "name": "BluRay",
      "pattern": "(?i)^(?=.*(?:bluray|blu-ray))(?!.*remux)",
      "tagColor": "#1A1A1A",
      "tagStyle": "filled",
      "textColor": "#FFFFFF",
      "type": "filter"
    },
    {
      "borderColor": "#00000000",
      "groupId": "gq",
      "id": "q-w",
      "imageURL": "https://raw.githubusercontent.com/9mousaa/BetterFormatter/main/images/mono-webdl.png",
      "isEnabled": true,
      "name": "WebDL",
